{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "macAccent": "#fe640b",
    "macRosewater": "#dc8a78",
    "macFlamingo": "#dd7878",
    "macPink": "#ea76cb",
    "macMauve": "#8839ef",
    "macRed": "#d20f39",
    "macMaroon": "#e64553",
    "macPeach": "#fe640b",
    "macYellow": "#df8e1d",
    "macGreen": "#40a02b",
    "macTeal": "#179299",
    "macSky": "#04a5e5",
    "macSapphire": "#209fb5",
    "macBlue": "#1e66f5",
    "macLavender": "#7287fd",
    "macText": "#4c4f69",
    "macSubtext1": "#5c5f77",
    "macSubtext0": "#6c6f85",
    "macOverlay2": "#7c7f93",
    "macOverlay1": "#8c8fa1",
    "macOverlay0": "#9ca0b0",
    "macSurface2": "#acb0be",
